# Copy this to .env (which is gitignored) and fill in real values.
# DO NOT commit .env.

# Required for `npx clawbus demo` (Anthropic Claude Agent SDK)
ANTHROPIC_API_KEY=sk-ant-...

# Required only if you use the DiscordAdapter (optional)
# Get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# The Discord channel where the bus will post and listen
DISCORD_CHANNEL_ID=
# Comma-separated Discord user IDs allowed to approve/reject via reactions
# (leave empty to allow no one — the adapter ignores all reactions)
DISCORD_REVIEWER_IDS=
